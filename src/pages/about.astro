---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import Features from '~/components/widgets/Features.astro';
import Content from '~/components/widgets/Content.astro';
import Timeline from '~/components/ui/Timeline.astro';

const metadata = {
  title: 'Über mich | Marc-Aurel Wilzin',
};
---

<Layout metadata={metadata}>
  <HeroText title="Über mich" subtitle="Mein Werdegang als Mobile Developer & Student" />

  <Timeline
    items={[
      { title: 'Informatik-Studium', description: 'Bachelor of Science, Eberhard Karls Universität Tübingen (seit Sept. 2024)', icon: 'tabler:school' },
      { title: 'Mobile Developer', description: 'page one GmbH, Nürnberg (seit Okt. 2021) – Architektur von Mobile Apps.', icon: 'tabler:briefcase' },
      { title: 'iOS-Developer Intern', description: 'Exaring AG, München (April 2022) – UI-Entwicklung für waipu.tv.', icon: 'tabler:device-mobile' },
      { title: 'Abitur', description: 'Theresien Gymnasium Ansbach (2024)', icon: 'tabler:certificate' },
    ]}
  />

  <Features
    title="Technische Skills"
    items={[
      { title: 'Dart / Flutter', description: 'Fortgeschritten', icon: 'tabler:brand-flutter' },
      { title: 'Swift', description: 'Mittel', icon: 'tabler:brand-swift' },
      { title: 'Git', description: 'Fortgeschritten', icon: 'tabler:brand-git' },
      { title: 'Firebase / Supabase', description: 'Mittel', icon: 'tabler:database' },
    ]}
  />

  <Content
    title="Projekte & Engagement"
    items={[
      { title: 'TVL Tennis App', description: 'Custom Court Booking System (Flutter/Node.js).' },
      { title: 'KirchenANführer', description: 'Gewinner des Bayerischen P-Seminar Preises.' },
      { title: 'Ehrenamt', description: 'Engagiert in Holocaust-Gedenkveranstaltungen.' },
    ]}
  />
</Layout>
